<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SampleApp.ViewModels"
             xmlns:mvvm="clr-namespace:Prism.Mvvm;assembly=Xe.Prism.Avalonia.Mobile"
             xmlns:regions="clr-namespace:Prism.Navigation.Regions;assembly=Xe.Prism.Avalonia.Mobile"
             x:Class="SampleApp.Views.ItemsRegionPage"
             x:DataType="vm:ItemsRegionViewModel"
             mvvm:ViewModelLocator.AutoWireViewModel="True">

    <ScrollViewer>
        <StackPanel Spacing="8" Margin="16">
            <TextBlock Text="ItemsControl Region" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="Each card auto-populated via View Discovery" FontSize="13" Foreground="Gray" TextWrapping="Wrap" />
            <ItemsControl Margin="0,8,0,0" regions:RegionManager.RegionName="ItemsRegion" />
        </StackPanel>
    </ScrollViewer>
</ContentPage>
