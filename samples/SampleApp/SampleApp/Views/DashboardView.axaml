<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SampleApp.ViewModels"
             x:Class="SampleApp.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <StackPanel Spacing="10" Margin="8">
        <TextBlock Text="Dashboard" FontSize="20" FontWeight="Bold" />
        <WrapPanel>
            <Border Background="#E8EAF6" CornerRadius="6" Padding="10" Width="100" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="5" FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="Pages" FontSize="11" Foreground="Gray" />
                </StackPanel>
            </Border>
            <Border Background="#E8EAF6" CornerRadius="6" Padding="10" Width="100" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="3" FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="Regions" FontSize="11" Foreground="Gray" />
                </StackPanel>
            </Border>
            <Border Background="#E8EAF6" CornerRadius="6" Padding="10" Width="100">
                <StackPanel>
                    <TextBlock Text="2" FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="Dialogs" FontSize="11" Foreground="Gray" />
                </StackPanel>
            </Border>
        </WrapPanel>
        <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="DarkGreen" />
    </StackPanel>
</UserControl>
