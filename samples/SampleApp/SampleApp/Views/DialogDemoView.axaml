<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SampleApp.ViewModels"
             x:Class="SampleApp.Views.DialogDemoView"
             x:DataType="vm:DialogDemoViewModel" Background="Coral">

    <StackPanel Spacing="14" Margin="24" MinWidth="300">
        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" />
        <TextBlock Text="{Binding Message}" FontSize="13" TextWrapping="Wrap" Foreground="#666666" />
        <Border Height="1" Background="#E0E0E0" Margin="0,4" />

        <TextBlock Text="Your response:" FontSize="13" FontWeight="SemiBold" />
        <TextBox PlaceholderText="Type something..." Text="{Binding UserInput}" />

        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" />
            <Button Content="OK" Command="{Binding CloseCommand}" />
        </StackPanel>
    </StackPanel>
</UserControl>
