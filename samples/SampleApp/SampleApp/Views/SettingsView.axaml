<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SampleApp.ViewModels"
             x:Class="SampleApp.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" />
        <CheckBox Content="Enable Notifications" IsChecked="{Binding NotificationsEnabled}" />
        <CheckBox Content="Dark Mode" IsChecked="{Binding DarkModeEnabled}" />
    </StackPanel>
</UserControl>
