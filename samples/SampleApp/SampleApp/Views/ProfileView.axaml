<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SampleApp.ViewModels"
             x:Class="SampleApp.Views.ProfileView"
             x:DataType="vm:ProfileViewModel">

    <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Profile" FontSize="20" FontWeight="Bold" />
        <Border Width="60" Height="60" CornerRadius="30" Background="#2196F3">
            <TextBlock Text="U" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <TextBlock Text="{Binding UserName}" FontSize="16" FontWeight="SemiBold" />
        <TextBlock Text="{Binding UserEmail}" FontSize="13" Foreground="Gray" />
    </StackPanel>
</UserControl>
